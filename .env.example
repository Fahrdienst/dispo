# =============================================================================
# Supabase
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# =============================================================================
# Application
# =============================================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000

# =============================================================================
# Google Maps
# =============================================================================
# Server-only: Geocoding, Directions API (used by lib/maps/client.ts)
GOOGLE_MAPS_API_KEY=your-server-api-key
# Server-only: Referenced by system health checks (actions/system.ts)
GOOGLE_MAPS_SERVER_API_KEY=your-server-api-key

# Client-only: Places Autocomplete, Static Maps
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-client-api-key

# =============================================================================
# Email (SMTP) -- used by system health checks (actions/system.ts)
# =============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM="Fahrdienst <noreply@example.com>"

# Gmail-specific (legacy transport, used by lib/mail/transport.ts)
GMAIL_USER=dispo-noreply@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
MAIL_FROM="Dispo Krankentransport <dispo-noreply@gmail.com>"

# Dispatcher escalation recipient email
DISPATCH_NOTIFICATION_EMAIL=dispatch@example.com

# =============================================================================
# Cron Job Authentication (required for acceptance escalation)
# =============================================================================
CRON_SECRET=your-cron-secret-here

# =============================================================================
# Feature Flags
# =============================================================================
ACCEPTANCE_FLOW_ENABLED=false

# =============================================================================
# Redis (Upstash) -- optional, for rate limiting / caching
# =============================================================================
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token

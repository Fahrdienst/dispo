# =============================================================================
# Supabase
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# =============================================================================
# Application
# =============================================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000

# =============================================================================
# Google Maps
# =============================================================================
# Server key for Web Service calls: Geocoding, Directions, Places Web Service
# (used by lib/maps/client.ts). MUST NOT have HTTP-referer restrictions —
# server-to-server requests send no Referer header and Google would reject them
# with "API keys with referer restrictions cannot be used with this API".
# In Google Cloud: Application restriction = None (Vercel egress IPs are
# dynamic); API restriction = Geocoding + Directions + Places only.
GOOGLE_MAPS_SERVER_API_KEY=your-unrestricted-server-api-key

# DEPRECATED legacy alias — only used as a fallback if GOOGLE_MAPS_SERVER_API_KEY
# is unset (getApiKey() logs a warning). Prefer GOOGLE_MAPS_SERVER_API_KEY.
GOOGLE_MAPS_API_KEY=

# Client (browser) key: Maps JavaScript API + Static Maps <img>. This one SHOULD
# have HTTP-referer restrictions (your domains). Never used for Web Service calls.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-referer-restricted-client-api-key

# =============================================================================
# Email (SMTP) -- used by system health checks (actions/system.ts)
# =============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM="Fahrdienst <noreply@example.com>"

# Gmail-specific (legacy transport, used by lib/mail/transport.ts)
GMAIL_USER=dispo-noreply@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
MAIL_FROM="Dispo Krankentransport <dispo-noreply@gmail.com>"

# Dispatcher escalation recipient email
DISPATCH_NOTIFICATION_EMAIL=dispatch@example.com

# =============================================================================
# Cron Job Authentication (required for acceptance escalation)
# =============================================================================
CRON_SECRET=your-cron-secret-here

# =============================================================================
# Feature Flags (see src/lib/feature-flags.ts for registry)
# =============================================================================
# Acceptance flow (driver confirmation via email)
ACCEPTANCE_FLOW_ENABLED=false
# New dispatcher flow (pilot rollout)
FEATURE_NEW_DISPO_FLOW=false
# Require MFA for all users
FEATURE_MFA_REQUIRED=false
# PDF generation for order sheets
FEATURE_PDF_GENERATION=false

# =============================================================================
# Redis (Upstash) -- optional, for rate limiting / caching
# =============================================================================
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token

# =============================================================================
# In-App Feedback -> GitHub Issues (Issue #88)
# =============================================================================
# Fine-grained PAT with "Issues: write" on the target repo (server-only!)
GITHUB_ISSUES_TOKEN=
# Target repository in owner/name form
GITHUB_ISSUES_REPO=Fahrdienst/dispo

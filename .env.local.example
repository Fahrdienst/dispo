# WARNING: Never commit real credentials! Use .env.local for actual values.
# Copy this file to .env.local and fill in real values.

# =============================================================================
# Supabase Configuration
# Get these from: https://supabase.com/dashboard/project/_/settings/api
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Service Role Key (server-only, NEVER expose to client)
# Used for admin operations like creating users
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# =============================================================================
# Application URL
# =============================================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000

# =============================================================================
# Google Maps
# =============================================================================
GOOGLE_MAPS_API_KEY=your-server-api-key-here
GOOGLE_MAPS_SERVER_API_KEY=your-server-api-key-here
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-client-api-key-here

# =============================================================================
# Gmail SMTP for driver notifications
# WARNING: Never commit real credentials! Use app-specific passwords.
# =============================================================================
GMAIL_USER=your-noreply@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
MAIL_FROM="Dispo Krankentransport <your-noreply@gmail.com>"

# =============================================================================
# SMTP (generic, used by system health checks)
# WARNING: Never commit real credentials!
# =============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM="Fahrdienst <noreply@example.com>"

# Dispatcher escalation recipient
DISPATCH_NOTIFICATION_EMAIL=dispatch@example.com

# =============================================================================
# Cron Job Authentication (required for acceptance escalation)
# =============================================================================
CRON_SECRET=your-cron-secret-here

# =============================================================================
# Feature Flags
# =============================================================================
ACCEPTANCE_FLOW_ENABLED=false

# =============================================================================
# Redis (Upstash) -- optional
# =============================================================================
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token

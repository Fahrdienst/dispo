#!/bin/sh

# Secret scanning pre-commit hook
# Checks staged files for patterns that indicate secrets

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

if [ -z "$STAGED_FILES" ]; then
  exit 0
fi

# Patterns that indicate secrets
PATTERNS=(
  "sk_live_"
  "sk_test_"
  "AKIA"
  "-----BEGIN.*PRIVATE KEY"
  "password\s*=\s*['\"][^'\"]*['\"]"
  "secret\s*=\s*['\"][^'\"]*['\"]"
)

FOUND=0

for pattern in "${PATTERNS[@]}"; do
  MATCHES=$(echo "$STAGED_FILES" | xargs grep -lE "$pattern" 2>/dev/null | grep -v ".example" | grep -v "node_modules" | grep -v ".husky")
  if [ -n "$MATCHES" ]; then
    if [ "$FOUND" -eq 0 ]; then
      echo ""
      echo "WARNING: Possible secret found in staged files!"
      echo "=========================================="
      FOUND=1
    fi
    echo "$STAGED_FILES" | xargs grep -nE "$pattern" 2>/dev/null | grep -v ".example" | grep -v ".husky"
  fi
done

if [ "$FOUND" -eq 1 ]; then
  echo ""
  echo "Please review the matches above."
  echo "If intentional: git commit --no-verify"
  exit 1
fi
